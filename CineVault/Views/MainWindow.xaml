<Window x:Class="CineVault.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CineVault.Converters"
        xmlns:vm="clr-namespace:CineVault.ViewModels"
        Title="CineVault" Height="820" Width="1360" MinWidth="1000" MinHeight="600"
        WindowStyle="None" ResizeMode="CanResize"
      
        Style="{StaticResource ThemedWindowStyle}"
       
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="52" ResizeBorderThickness="5"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:PathToImageConverter x:Key="PathToImage" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 0 — Custom Title Bar (full width, spans both content columns)
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#33000000" Offset="0" />
                    <GradientStop Color="#22000000" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: branding + movie count -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="🎬" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="CineVault" FontSize="19" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <Border Background="#33000000" CornerRadius="20" Padding="10,3"
                        Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FilteredMovies.Count, StringFormat='{}{0} movies'}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                </Border>
            </StackPanel>

            <!-- Right: Settings + window controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <Button Content="⚙" Style="{StaticResource TitleBarButton}"
                        Command="{Binding OpenSettingsCommand}" ToolTip="Settings"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <Button Content="—" Style="{StaticResource TitleBarButton}"
                        Click="Minimize_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <Button x:Name="MaximizeButton" Content="□"
                        Style="{StaticResource TitleBarButton}"
                        Click="Maximize_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        Click="CloseWindow_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 1 — Two-column content area
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*" />
                <ColumnDefinition Width="40*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LEFT: Library (60%) ══════════════ -->
            <Grid Grid.Column="0" Margin="20,14,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search + Update Library -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ThemedTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="1" Content="⟳  Update Library"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ScanLibraryCommand}" />
                </Grid>

                <!-- Poster grid: 3 columns, scrollable -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding FilteredMovies}"
                             SelectedItem="{Binding SelectedMovie}"
                             Style="{StaticResource ThumbnailListBox}"
                             ItemContainerStyle="{StaticResource ThumbnailListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MovieItemViewModel}">
                                <Border Width="200" Height="250" CornerRadius="8" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding PosterPath, Converter={StaticResource PathToImage}}"
                                               Stretch="UniformToFill" />
                                        <Border VerticalAlignment="Bottom" Height="58">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0" />
                                                    <GradientStop Color="#E0000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Bottom" Margin="8,0,8,7" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Status bar -->
                <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" Margin="0,10,0,0" />
            </Grid>

            <!-- ══════════════ RIGHT: Details (40%) ══════════════ -->
            <Border Grid.Column="1" Margin="10,14,20,20" CornerRadius="16" ClipToBounds="True">
                <Grid>
                    <!-- Blurred movie poster as background -->
                    <Image Source="{Binding SelectedMovie.Movie.PosterPath, Converter={StaticResource PathToImage}}"
                           Stretch="UniformToFill">
                        <Image.Effect>
                            <BlurEffect Radius="35" />
                        </Image.Effect>
                    </Image>

                    <!-- Dark gradient overlay -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#AA1B1320" Offset="0" />
                                <GradientStop Color="#EE1B1320" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Empty state placeholder -->
                    <TextBlock Text="Select a movie to see its details"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="40" />

                    <!-- Loading indicator while AI/TMDb fetch runs -->
                    <StackPanel Visibility="{Binding IsLoadingDetails, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0">
                        <TextBlock Text="Fetching movie info…"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Movie details -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="24">

                            <!-- Poster + title/meta/buttons -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="110" Height="160" CornerRadius="10" ClipToBounds="True">
                                    <Image Source="{Binding SelectedMovie.Movie.PosterPath, Converter={StaticResource PathToImage}}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding SelectedMovie.Movie.Title}"
                                               FontSize="21" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SelectedMovie.Movie.ReleaseDate}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Text="  •  ⭐ "
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Text="{Binding SelectedMovie.Movie.Rating, StringFormat={}{0:0.0}}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="▶  Play" Style="{StaticResource AccentButton}"
                                                Command="{Binding PlayMovieCommand}" Margin="0,0,10,0" />
                                        <Button Content="🎞  Trailer" Style="{StaticResource GhostButton}"
                                                Command="{Binding OpenTrailerCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Overview -->
                            <TextBlock Text="Overview" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding SelectedMovie.Movie.Overview}"
                                       TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20" />

                            <!-- Cast -->
                            <TextBlock Text="Cast" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding Cast}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CastMemberViewModel}">
                                        <StackPanel Width="80" Margin="0,0,12,0">
                                            <Border Width="70" Height="70" CornerRadius="35"
                                                    ClipToBounds="True" Background="#332A1330"
                                                    HorizontalAlignment="Center">
                                                <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding Character}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" TextWrapping="Wrap"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
