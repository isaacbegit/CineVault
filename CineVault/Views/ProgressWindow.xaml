<Window x:Class="CineVault.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="380" Height="210" ResizeMode="NoResize"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">

    <Border CornerRadius="18" Margin="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F21B1320" Offset="0"/>
                <GradientStop Color="#F24A0826" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.75" Color="#FF000000"/>
        </Border.Effect>

        <Grid>
            <!-- Orange accent stripe at top -->
            <Border VerticalAlignment="Top" Height="4" CornerRadius="18,18,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFA559" Offset="0"/>
                        <GradientStop Color="#FF7B1142" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32,20,32,24">

                <!-- Spinner -->
                <Viewbox Width="58" Height="58" HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Canvas Width="60" Height="60">
                        <!-- Ghost track ring -->
                        <Ellipse Width="50" Height="50" Canvas.Left="5" Canvas.Top="5"
                                 Stroke="#22FFFFFF" StrokeThickness="5" Fill="Transparent"/>
                        <!-- Animated arc -->
                        <Path Data="M 30,5 A 25,25 0 1 1 5,30"
                              StrokeThickness="5" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                              Fill="Transparent">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFA559" Offset="0"/>
                                    <GradientStop Color="#FF7B1142" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" CenterX="30" CenterY="30"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:0.9"
                                                             RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Canvas>
                </Viewbox>

                <!-- Title -->
                <TextBlock Text="Updating Library" FontSize="16" FontWeight="Bold"
                           Foreground="#FFFFF4EC" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- Live progress message -->
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="#FFD9C2CE" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="290"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
