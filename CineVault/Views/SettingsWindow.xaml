<Window x:Class="CineVault.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CineVault — Settings" Height="600" Width="540"
        Style="{StaticResource ThemedWindowStyle}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,18" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Movies Root Folder" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ThemedTextBox}"
                             Text="{Binding MoviesRootFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Browse..." Style="{StaticResource GhostButton}"
                            Command="{Binding BrowseFolderCommand}" />
                </Grid>
                <TextBlock Text="The folder that directly contains one sub-folder per movie."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,16" />

                <TextBlock Text="External Player (e.g. VLC, MPC-HC, PotPlayer)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ThemedTextBox}"
                             Text="{Binding ExternalPlayerPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Browse..." Style="{StaticResource GhostButton}"
                            Command="{Binding BrowsePlayerCommand}" />
                </Grid>

                <Separator Margin="0,6,0,16" Opacity="0.2" />

                <TextBlock Text="TMDb API Key (free, recommended)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <TextBox Style="{StaticResource ThemedTextBox}"
                         Text="{Binding TmdbApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                <TextBlock Text="Get a free key at themoviedb.org → Settings → API. Powers movie info, cast photos, trailer and the trending backdrop image."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" />

                <TextBlock Text="AI Provider (optional — AI-written summaries)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <ComboBox Style="{StaticResource ThemedComboBox}" Margin="0,0,0,12"
                          ItemsSource="{Binding AiProviders}" SelectedItem="{Binding AiProvider}" />

                <TextBlock Text="AI API Key" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <TextBox Style="{StaticResource ThemedTextBox}"
                         Text="{Binding AiApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="AI Model" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                <TextBox Style="{StaticResource ThemedTextBox}"
                         Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <CheckBox Content="Prefer AI-generated summary over the TMDb overview"
                          Style="{StaticResource ThemedCheckBox}"
                          IsChecked="{Binding PreferAiSummary}" Margin="0,0,0,8" />
                <TextBlock Text="Google Gemini has a generous free tier — get a key at aistudio.google.com/apikey."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" />

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,10,0" />
            <Button Content="Save" Style="{StaticResource AccentButton}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
